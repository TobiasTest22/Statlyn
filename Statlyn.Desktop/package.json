{
  "name": "statlyn-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run build",
    "build": "tsc && vite build",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:lowmem": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:CARGO_BUILD_JOBS='1'; $env:CARGO_INCREMENTAL='0'; npx tauri build\"",
    "tauri:build:nobundle": "tauri build --no-bundle",
    "desktop:validate": "powershell -NoProfile -ExecutionPolicy Bypass -File ../tools/run-desktop-build-diagnostics.ps1",
    "desktop:validate:quick": "powershell -NoProfile -ExecutionPolicy Bypass -File ../tools/run-desktop-build-diagnostics.ps1 -SkipTauriBuild",
    "desktop:validate:lowmem": "powershell -NoProfile -ExecutionPolicy Bypass -File ../tools/run-desktop-build-diagnostics.ps1 -LowMemory"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.0"
  }
}
