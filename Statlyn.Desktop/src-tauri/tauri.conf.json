{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Statlyn",
  "version": "0.1.0",
  "identifier": "com.statlyn.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Statlyn",
        "width": 1440,
        "height": 940,
        "minWidth": 1100,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:5118 http://127.0.0.1:5118 http://localhost:5173 ws://localhost:5173; img-src 'self' data:; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
